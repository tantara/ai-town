# --- Frontend (.env.local) ----------------------------------------------------

# Supabase project — anon key only (public safe). RLS policies in
# supabase/migrations/00000000000001_init.sql gate what the browser can read.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Cloudflare Worker public URL — `wrangler dev` defaults to 127.0.0.1:8787.
# In production set this to https://ai-world.<account>.workers.dev.
NEXT_PUBLIC_WORKER_URL=http://127.0.0.1:8787

# Optional: render extra debug overlays.
NEXT_PUBLIC_SHOW_DEBUG_UI=

# NextAuth
AUTH_SECRET=change-me
GITHUB_ID=
GITHUB_SECRET=

# --- Seed script (process.env, not exposed to browser) ------------------------

# Service-role key — never put in NEXT_PUBLIC_ vars. Only used by `pnpm seed`,
# the Next.js music upload route, and the Cloudflare Worker
# (via `wrangler secret put` for production).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...

WORKER_URL=http://127.0.0.1:8787

# --- LLM provider -------------------------------------------------------------
# Pick one: openai | openrouter | together | ollama | custom.
# Set on the Cloudflare Worker via `wrangler secret put` (or local `.dev.vars`).
# LLM_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai). Default chat model: deepseek/deepseek-v4-flash.
# OpenRouter does not host embeddings — set an embedding model from another
# provider or use Ollama for local embeddings.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash
# OPENROUTER_EMBEDDING_MODEL=text-embedding-ada-002
# OPENROUTER_REFERER=https://your-app.example.com
# OPENROUTER_TITLE=AI World
